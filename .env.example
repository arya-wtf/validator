# =============================================================================
# REQUIRED — OpenAI API key (server-side only, NEVER expose to client)
# Get it from: https://platform.openai.com/api-keys
# Model used: gpt-5.4 (configured in src/app/api/analyze/route.ts)
# =============================================================================
OPENAI_API_KEY=sk-proj-your-key-here

# =============================================================================
# REQUIRED — App authentication
# Hardcoded users: arya, dewi (both share AUTH_PASSWORD)
# Generate AUTH_SECRET with: openssl rand -hex 32
# =============================================================================
AUTH_PASSWORD=Rahasia123!
AUTH_SECRET=replace-with-openssl-rand-hex-32

# =============================================================================
# REQUIRED — GitHub Personal Access Token (for auto-saving runs as .md files)
# Get it from: https://github.com/settings/tokens?type=beta
# Required scopes: Contents (Read and write) on this repo only
# =============================================================================
GITHUB_TOKEN=github_pat_your-token-here
GITHUB_OWNER=arya-wtf
GITHUB_REPO=idea-validator
GITHUB_BRANCH=main

# =============================================================================
# OPTIONAL — Vercel deploy hook (so app rebuilds immediately after committing)
# Get it from: Vercel project settings → Git → Deploy Hooks → Create Hook
# Without this, Vercel still rebuilds on push but takes ~30s longer to detect
# =============================================================================
VERCEL_DEPLOY_HOOK_URL=

# =============================================================================
# OPTIONAL — kept as escape hatch in package.json if OpenAI quality is bad.
# Not currently read by any route. Uncomment if you swap providers back.
# =============================================================================
# ANTHROPIC_API_KEY=sk-ant-your-key-here
